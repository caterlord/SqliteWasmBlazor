{
  "name": "sqlitewasmblazor-crypto-typescript",
  "version": "1.0.0",
  "description": "Noble.js + SubtleCrypto hybrid for SqliteWasmBlazor.Crypto",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @sqlitewasmblazor/crypto-core && esbuild src/index.ts --bundle --format=esm --sourcemap=inline --outfile=../wwwroot/noble-prf.js",
    "build:release": "npm run build -w @sqlitewasmblazor/crypto-core && esbuild src/index.ts --bundle --format=esm --minify --outfile=../wwwroot/noble-prf.js",
    "test": "npm test -w @sqlitewasmblazor/crypto-core"
  },
  "devDependencies": {
    "esbuild": "0.27.7",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@awasm/noble": "0.1.1",
    "@noble/curves": "1.9.7"
  }
}
