@page "/password-test"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using SqliteWasmBlazor
@using SqliteWasmBlazor.TestApp.TestInfrastructure.VfsEncryption
@using System.Security.Cryptography
@using System.Text
@inject ISqliteWasmDatabaseService DatabaseService

<PageTitle>Password-based VFS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">Password-based encryption</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">
        Integration test for <code>UseSqliteWasmPassword</code> / the worker's
        <code>openWithPassword</code> path. First use of a password creates a random
        salt stored in the SAHPool header and derives a 32-byte key via Argon2id;
        subsequent opens re-derive the same key. A wrong password fails cleanly.
    </MudText>

    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password"
                      Variant="Variant.Outlined" Immediate="true" Disabled="@_busy" />
        <MudTextField @bind-Value="_noteBody" Label="Note (optional, will be inserted on open)"
                      Variant="Variant.Outlined" Class="mt-3" Disabled="@_busy" />

        <MudStack Row="true" Class="mt-3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_busy"
                       OnClick="OpenAsync">Open / Create</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@_busy"
                       OnClick="WipeAsync">Wipe DB</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Tertiary" Disabled="@_busy"
                       OnClick="RunFullIntegrationAsync">Run full integration</MudButton>
        </MudStack>
    </MudPaper>

    @if (_busy)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
    }

    @if (_log.Count > 0)
    {
        <MudPaper Class="pa-3" Elevation="0" Style="background-color:#fafafa;">
            <MudText Typo="Typo.subtitle2" GutterBottom="true">Log</MudText>
            @foreach (var line in _log)
            {
                <MudText Typo="Typo.body2" Style="@LineStyle(line)">@line.Text</MudText>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    private const string DbName = "PasswordTestDb.db";

    private string _password = string.Empty;
    private string _noteBody = string.Empty;
    private bool _busy;
    private readonly List<LogLine> _log = new();

    private async Task OpenAsync()
    {
        if (string.IsNullOrEmpty(_password))
        {
            AddError("Password is empty.");
            return;
        }

        _busy = true;
        try
        {
            var existsBefore = await DatabaseService.ExistsDatabaseAsync(DbName);
            AddInfo(existsBefore
                ? $"{DbName} exists — will try to open with the given password."
                : $"{DbName} does not exist — will create with the given password.");

            // Materialize the password into a byte[] that we can
            // zeroize deterministically. The source `_password` string is
            // immutable and pinned by the Blazor component state — the web
            // platform doesn't offer a text input that writes into a caller-
            // owned byte buffer, so the string copy leaks to GC. We contain
            // the exposure to the shortest possible window by keeping the
            // byte[] in a `try/finally` and zeroing it on exit.
            var pwBytes = Encoding.UTF8.GetBytes(_password);
            try
            {
                var connection = new SqliteWasmConnection($"Data Source={DbName}")
                {
                    EncryptionPassword = pwBytes,
                };

                var builder = new DbContextOptionsBuilder<PasswordTestContext>();
                builder.UseSqliteWasm(connection);
                var options = builder.Options;

                await using var ctx = new PasswordTestContext(options);
                try
                {
                    await ctx.Database.EnsureCreatedAsync();
                }
                catch (Exception ex) when (IsLikelyWrongPassword(ex) && existsBefore)
                {
                    AddError(
                        $"Wrong password for existing {DbName}. Either enter the original password " +
                        $"or click \"Wipe DB\" to start fresh.");
                    return;
                }
                catch (Exception ex)
                {
                    AddError($"Open failed: {ex.GetType().Name}: {ex.Message}");
                    return;
                }

                var rowCount = await ctx.Notes.CountAsync();
                AddOk($"Opened {DbName}; {rowCount} existing notes.");

                if (!string.IsNullOrEmpty(_noteBody))
                {
                    ctx.Notes.Add(new PasswordNote
                    {
                        Title = DateTime.Now.ToString("HH:mm:ss"),
                        Body = _noteBody,
                    });
                    await ctx.SaveChangesAsync();
                    AddInfo($"Inserted note: \"{_noteBody}\"");
                }

                var notes = await ctx.Notes.OrderBy(x => x.Id).ToListAsync();
                foreach (var n in notes)
                {
                    AddInfo($"  #{n.Id} [{n.Title}] {n.Body}");
                }

                // Echo the most recent note's body back into the input field
                // as a visual confirmation that the decrypt round-trip worked.
                if (notes.Count > 0)
                {
                    _noteBody = notes[^1].Body;
                }

                await DatabaseService.CloseDatabaseAsync(DbName);
            }
            finally
            {
                // Zero the byte[] copy the moment it's no longer needed.
                // The bridge also copies+zeroes its own serialized envelope
                // (see SqliteWasmWorkerBridge.OpenDatabaseWithPasswordAsync)
                // and the worker wipes the Uint8Array it unpacks — so the
                // only remaining reference to the password after this point
                // is the immutable `_password` string in Blazor component
                // state, which the platform provides no way to zero.
                CryptographicOperations.ZeroMemory(pwBytes);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>
    /// SQLite surfaces an AEAD authentication failure from our VFS as
    /// SQLITE_IOERR (code 10). That's indistinguishable from a real disk
    /// error by SQLite itself, but in our context — against an existing
    /// encrypted DB — it almost always means the password is wrong and
    /// slot 0 couldn't be decrypted. We still show the raw error in the
    /// non-matching branch so genuine I/O problems aren't hidden.
    /// </summary>
    private static bool IsLikelyWrongPassword(Exception ex)
    {
        var msg = ex.ToString();
        return msg.Contains("SQLITE_IOERR", StringComparison.Ordinal)
            || msg.Contains("disk I/O error", StringComparison.Ordinal)
            || msg.Contains("SQLITE_NOTADB", StringComparison.Ordinal);
    }

    private async Task WipeAsync()
    {
        _busy = true;
        try
        {
            await DatabaseService.DeleteDatabaseAsync(DbName);
            AddInfo($"Deleted {DbName}.");
        }
        catch (Exception ex)
        {
            AddError($"Wipe failed: {ex.Message}");
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RunFullIntegrationAsync()
    {
        _busy = true;
        _log.Clear();

        // Password buffers declared here and zeroized in the outer finally,
        // regardless of which phase succeeds/fails.
        byte[]? pw1 = null;
        byte[]? pw1Wrong = null;
        try
        {
            AddInfo("=== Full password-based integration ===");

            // Start clean.
            await DatabaseService.DeleteDatabaseAsync(DbName);

            pw1 = Encoding.UTF8.GetBytes("correct-horse-battery-staple");
            pw1Wrong = Encoding.UTF8.GetBytes("correct-horse-battery-stapl3");

            // --- Create + seed with correct password ---
            await using (var ctx = NewContext(pw1))
            {
                await ctx.Database.EnsureCreatedAsync();
                ctx.Notes.Add(new PasswordNote { Title = "seed", Body = "hello encrypted world" });
                await ctx.SaveChangesAsync();
                AddInfo("Phase 1: created DB, inserted 1 note.");
            }
            await DatabaseService.CloseDatabaseAsync(DbName);

            // --- Reopen with same password, read back ---
            await using (var ctx = NewContext(pw1))
            {
                var n = await ctx.Notes.FirstOrDefaultAsync();
                if (n is null || n.Body != "hello encrypted world")
                {
                    AddError($"Phase 2 FAIL: expected seed row, got {n?.Body ?? "null"}");
                    return;
                }
                AddOk($"Phase 2: reopen with same password read back \"{n.Body}\"");
            }
            await DatabaseService.CloseDatabaseAsync(DbName);

            // --- Reopen with wrong password, expect failure ---
            try
            {
                await using var ctx = NewContext(pw1Wrong);
                var rows = await ctx.Notes.ToListAsync();
                AddError(
                    $"Phase 3 FAIL: wrong password returned {rows.Count} rows (should have thrown)");
                return;
            }
            catch (Exception ex)
            {
                var leaked = ex.ToString().Contains("hello encrypted world");
                if (leaked)
                {
                    AddError("Phase 3 FAIL: plaintext leaked through wrong-password error path");
                    return;
                }
                AddOk($"Phase 3: wrong password rejected cleanly ({ex.GetType().Name})");
            }
            try { await DatabaseService.CloseDatabaseAsync(DbName); } catch { }

            // --- Reopen with correct password again, data still there ---
            await using (var ctx = NewContext(pw1))
            {
                var n = await ctx.Notes.FirstOrDefaultAsync();
                if (n?.Body != "hello encrypted world")
                {
                    AddError("Phase 4 FAIL: data lost after wrong-password attempt");
                    return;
                }
                AddOk("Phase 4: correct password still works after wrong attempt.");
            }
            await DatabaseService.CloseDatabaseAsync(DbName);

            AddOk("=== ALL PHASES PASSED ===");
        }
        catch (Exception ex)
        {
            AddError($"Unhandled: {ex.GetType().Name}: {ex.Message}");
        }
        finally
        {
            // Zero both password byte[]s the moment they're no longer needed.
            if (pw1 is not null) CryptographicOperations.ZeroMemory(pw1);
            if (pw1Wrong is not null) CryptographicOperations.ZeroMemory(pw1Wrong);
            _busy = false;
        }
    }

    /// <summary>
    /// Caller MUST own the `password` byte[] and zero it after the returned
    /// context is fully consumed. The bridge creates its own (zero'd)
    /// envelope copy for the worker call — this byte[] only lives as long
    /// as the caller holds it, and the SqliteWasmConnection doesn't take
    /// ownership of the buffer.
    /// </summary>
    private static PasswordTestContext NewContext(byte[] password)
    {
        var connection = new SqliteWasmConnection($"Data Source={DbName}")
        {
            EncryptionPassword = password,
        };
        var builder = new DbContextOptionsBuilder<PasswordTestContext>();
        builder.UseSqliteWasm(connection);
        return new PasswordTestContext(builder.Options);
    }

    private void AddInfo(string s) => _log.Add(new LogLine(s, LogLevel.Info));
    private void AddOk(string s) => _log.Add(new LogLine(s, LogLevel.Ok));
    private void AddError(string s) => _log.Add(new LogLine(s, LogLevel.Error));

    private static string LineStyle(LogLine line) => line.Level switch
    {
        LogLevel.Error => "color: #c62828;",
        LogLevel.Ok => "color: #2e7d32;",
        _ => "color: #555;",
    };

    private enum LogLevel { Info, Ok, Error }
    private sealed record LogLine(string Text, LogLevel Level);
}
