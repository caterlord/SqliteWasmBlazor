{
  "name": "sqlitewasmblazor-components-typescript",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run ensure:outdir && npm run build:fileops && npm run copy:files",
    "build:fileops": "esbuild file-operations.ts --bundle --format=esm --sourcemap=inline --outfile=../bundles/file-operations.js",
    "build:release": "npm run ensure:outdir && npm run build:fileops:release && npm run copy:files",
    "build:fileops:release": "esbuild file-operations.ts --bundle --format=esm --minify --outfile=../bundles/file-operations.js",
    "ensure:outdir": "mkdir -p ../bundles",
    "copy:files": "echo 'No additional files to copy'"
  },
  "devDependencies": {
    "esbuild": "0.27.2",
    "typescript": "5.9.3"
  }
}
