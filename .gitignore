## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Node modules
node_modules/

# TypeScript build output
*.js.map

# esbuild bundles + sqlite-wasm copy regenerated by each csproj's
# BuildTypeScriptBundles target on every dotnet build. These ship to NuGet
# consumers as StaticWebAsset items registered inside the target body — they
# must NOT live under wwwroot/ because the Razor SDK auto-includes that path
# at MSBuild item-evaluation time and freezes a stale Integrity hash before
# our npm build can overwrite the file (produces internally-inconsistent
# nupkgs whose StaticWebAssets.props Integrity differs from packed bytes →
# downstream Service Worker SRI block at runtime).
src/Base/SqliteWasmBlazor/bundles/
src/Base/SqliteWasmBlazor.Components/bundles/
src/Crypto/SqliteWasmBlazor.Crypto/bundles/

# Local-only dev scripts (smoke-test helpers, deep-clean recipes, etc.)
scripts/

# Delta relay runtime artifacts — generated by the relay-config init
# and the LiveRelay integration tests. relay-config.example.php is
# the operator template; relay-config.php is per-deployment.
DeltaRelay/relay-config.php
DeltaRelay/relay.db
DeltaRelay/relay.db-wal
DeltaRelay/relay.db-shm

# OS files
.DS_Store
Thumbs.db

# Build outputs
*.dll
*.exe
*.pdb
*.cache
*.log

# NuGet packages
*.nupkg
*.snupkg

# Compiled files
*.a
!src/Base/SqliteWasmBlazor/native/lib/e_sqlite3.a
*.so
*.dylib

# Temporary files
*.tmp
*.temp
.nuget
src/Base/SqliteWasmBlazor/native/lib/sqlite3_stub.o

# Internal documentation
docs/internal/
src/Base/SqliteWasmBlazor/package-lock.json
.claude/CLAUDE.md
.claude/scheduled_tasks.lock
.claude/settings.local.json
SqliteWasmBlazorInternal.slnx

*.lscache
