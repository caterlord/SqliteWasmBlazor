@using Microsoft.EntityFrameworkCore
@using SqliteWasmBlazor
@using SqliteWasmBlazor.Models
@inject IDbInitializationStatus DbInitializationStatus
@inject IDbInitializationReporter DbInitializationReporter
@inject IDbContextFactory<TodoDbContext> DbContextFactory
@inject IDbContextFactory<NoteDbContext> NoteDbContextFactory
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject ISqliteWasmDatabaseService DatabaseService
@implements IDisposable

@if (DbInitializationStatus.Failure is { } failure)
{
    <MudAlert Severity="Severity.Error" Class="mb-6" Variant="Variant.Filled">
        <MudText Typo="Typo.h6" Class="mb-2">Database Error</MudText>

        @switch (failure)
        {
            case TabLockedFailure or TimeoutFailure:
                <MudText Typo="Typo.body1" Class="mb-3">@failure.DefaultMessage</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@(() => NavigationManager.NavigateTo(NavigationManager.BaseUri, forceLoad: true))"
                           StartIcon="@Icons.Material.Filled.Refresh">
                    Reload
                </MudButton>
                break;

            case SchemaIncompatibleFailure schema:
                <MudText Typo="Typo.body1" Class="mb-2">@schema.DefaultMessage</MudText>
                @if (schema.Mismatches.Count > 0)
                {
                    <MudText Typo="Typo.body2" Class="mb-3">
                        Mismatches detected:
                        <ul>
                            @foreach (var m in schema.Mismatches)
                            {
                                <li>
                                    <code>@m.Table</code>:
                                    @if (m.MissingColumn is not null)
                                    {
                                        <text> missing column <code>@m.MissingColumn</code></text>
                                    }
                                    else if (m.ExtraColumn is not null)
                                    {
                                        <text> unexpected column <code>@m.ExtraColumn</code></text>
                                    }
                                </li>
                            }
                        </ul>
                    </MudText>
                }
                @ResetButton()
                break;

            case GenericInitFailure generic:
                <MudText Typo="Typo.body1" Style="white-space: pre-line;" Class="mb-3">@generic.DefaultMessage</MudText>
                @ResetButton()
                break;

            default:
                <MudText Typo="Typo.body1" Style="white-space: pre-line;" Class="mb-3">@failure.DefaultMessage</MudText>
                @ResetButton()
                break;
        }
    </MudAlert>
}

@code {
    private bool _isResetting;

    protected override void OnInitialized()
    {
        DbInitializationStatus.Changed += OnStatusChanged;
    }

    public void Dispose()
    {
        DbInitializationStatus.Changed -= OnStatusChanged;
    }

    private void OnStatusChanged() => InvokeAsync(StateHasChanged);

    private RenderFragment ResetButton() => __builder =>
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Warning"
                   OnClick="ResetDatabaseAsync"
                   StartIcon="@Icons.Material.Filled.RestartAlt"
                   Disabled="_isResetting">
            @if (_isResetting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Resetting...</span>
            }
            else
            {
                <span>Reset Database</span>
            }
        </MudButton>
    };

    private async Task ResetDatabaseAsync()
    {
        _isResetting = true;
        StateHasChanged();

        try
        {
            await DatabaseService.DeleteDatabaseAsync("TodoDb.db");
            await DatabaseService.DeleteDatabaseAsync("NotesDb.db");

            await using var todoContext = await DbContextFactory.CreateDbContextAsync();
            await todoContext.Database.MigrateAsync();

            await using var noteContext = await NoteDbContextFactory.CreateDbContextAsync();
            await noteContext.Database.MigrateAsync();

            DbInitializationReporter.Report(DbInitState.READY);

            Snackbar.Add("Database reset successfully! Reloading page...", Severity.Success);

            await Task.Delay(1000);
            NavigationManager.NavigateTo(NavigationManager.BaseUri, forceLoad: true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Database reset failed: {ex.Message}", Severity.Error);
            DbInitializationReporter.Report(
                DbInitState.FAILED,
                new GenericInitFailure(string.Empty, ex));
        }
        finally
        {
            _isResetting = false;
            StateHasChanged();
        }
    }
}
