## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# Node modules
node_modules/

# TypeScript build output
*.js.map

# esbuild bundles + sqlite-wasm copy regenerated by each csproj's npm
# <Exec> chain on every dotnet build. Do not track — bundle drift between
# source and committed copy is otherwise easy to miss.
src/Base/SqliteWasmBlazor/wwwroot/sqlite-wasm-bridge.js
src/Base/SqliteWasmBlazor/wwwroot/sqlite-wasm-worker.js
src/Base/SqliteWasmBlazor/wwwroot/sqlite3.wasm
src/Base/SqliteWasmBlazor.Components/wwwroot/file-operations.js

# OS files
.DS_Store
Thumbs.db

# Build outputs
*.dll
*.exe
*.pdb
*.cache
*.log

# NuGet packages
*.nupkg
*.snupkg

# Compiled files
*.a
!src/Base/SqliteWasmBlazor/native/lib/e_sqlite3.a
*.so
*.dylib

# Temporary files
*.tmp
*.temp
.nuget
src/Base/SqliteWasmBlazor/native/lib/sqlite3_stub.o

# Internal documentation
docs/internal/
src/Base/SqliteWasmBlazor/package-lock.json
.claude/CLAUDE.md
.claude/scheduled_tasks.lock
.claude/settings.local.json
SqliteWasmBlazorInternal.slnx

*.lscache
