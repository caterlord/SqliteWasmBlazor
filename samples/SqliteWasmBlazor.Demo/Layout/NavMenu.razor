<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
    @if (DbInitializationStatus.State == DbInitState.READY)
    {
        <MudNavLink Href="todos" Icon="@Icons.Material.Filled.CheckBox">Todo List</MudNavLink>
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudNavLink Href="multiview" Icon="@Icons.Material.Filled.ViewQuilt">Multi View</MudNavLink>
        </MudHidden>
        <MudNavLink Href="multidatabase" Icon="@Icons.Material.Filled.Storage">Multi-Database</MudNavLink>
        <MudNavLink Href="database-import-export" Icon="@Icons.Material.Filled.SwapVert">Import/Export</MudNavLink>
        <MudNavLink Href="administration" Icon="@Icons.Material.Filled.Settings">Administration</MudNavLink>
    }
</MudNavMenu>

@code
{
    [Inject]
    public required IDbInitializationStatus DbInitializationStatus { get; init; }
}
