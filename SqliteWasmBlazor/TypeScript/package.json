{
  "name": "system-data-sqlite-wasm-typescript",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "patch-package",
    "build": "npm run build:worker && npm run build:bridge && npm run copy:wasm",
    "build:worker": "esbuild worker/sqlite-worker.ts --bundle --format=esm --sourcemap=inline --outfile=../wwwroot/sqlite-wasm-worker.js",
    "build:bridge": "esbuild bridge/worker-bridge.ts --bundle --format=esm --sourcemap=inline --outfile=../wwwroot/sqlite-wasm-bridge.js",
    "copy:wasm": "cp node_modules/@sqlite.org/sqlite-wasm/dist/sqlite3.wasm ../wwwroot/",
    "build:release": "npm run build:worker:release && npm run build:bridge:release && npm run copy:wasm",
    "build:worker:release": "esbuild worker/sqlite-worker.ts --bundle --format=esm --minify --outfile=../wwwroot/sqlite-wasm-worker.js",
    "build:bridge:release": "esbuild bridge/worker-bridge.ts --bundle --format=esm --minify --outfile=../wwwroot/sqlite-wasm-bridge.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sqlitewasmblazor/crypto-core": "file:../../SqliteWasmBlazor.Crypto/TypeScript/packages/crypto-core",
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0",
    "@sqlite.org/sqlite-wasm": "3.51.2-build9",
    "msgpackr": "1.11.10"
  },
  "devDependencies": {
    "esbuild": "0.27.7",
    "patch-package": "8.0.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
