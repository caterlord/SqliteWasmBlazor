@inherits RegistrationModelComponent

<MudCard>
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Primary" />
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Register Passkey</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">Create a new passkey with PRF support</MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        @if (Model.IsPrfSupported is null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                <MudText>Checking PRF support...</MudText>
            </MudStack>
        }
        else if (Model.IsPrfSupported == false)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                The WebAuthn PRF extension is not supported on this device or browser. CryptoSync requires PRF.
            </MudAlert>
        }
        else
        {
            <MudTextField @bind-Value="@Model.DisplayName"
                          Label="Display Name (optional)"
                          Variant="Variant.Outlined"
                          HelperText="A friendly name for this passkey"
                          Class="mb-4"
                          Disabled="@Model.Register.Executing" />
        }
    </MudCardContent>

    <MudCardActions>
        <MudButtonAsyncRx Command="@Model.Register"
                          Variant="Variant.Filled"
                          Color="Color.Primary"
                          StartIcon="@Icons.Material.Filled.Key">
            Register Passkey
        </MudButtonAsyncRx>
    </MudCardActions>
</MudCard>
