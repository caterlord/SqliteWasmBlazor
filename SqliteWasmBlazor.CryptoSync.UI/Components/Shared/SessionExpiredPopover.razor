@inherits SessionExpiredPopoverModelComponent

<MudOverlay Visible="@Model.Visible"
            DarkBackground="true"
            ZIndex="2000"
            LockScroll="true">
    <MudAlert Severity="Severity.Warning"
              Variant="Variant.Filled"
              NoIcon="true"
              Class="pa-4"
              Style="max-width: 400px;">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Large" />
                <MudText Typo="Typo.h6">Session Expired</MudText>
            </MudStack>

            <MudText Typo="Typo.body1">
                @Message
            </MudText>

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudButtonAsyncRx Command="@Model.Dismiss"
                                  Variant="Variant.Text"
                                  Color="Color.Dark"
                                  Size="Size.Small">
                    @DismissLabel
                </MudButtonAsyncRx>
                <MudButtonAsyncRx Command="@Model.ReAuthenticate"
                                  Variant="Variant.Filled"
                                  Color="Color.Dark"
                                  StartIcon="@Icons.Material.Filled.Fingerprint"
                                  Size="Size.Small">
                    @ReAuthenticateLabel
                </MudButtonAsyncRx>
            </MudStack>
        </MudStack>
    </MudAlert>
</MudOverlay>
