@inherits RegistrationModelComponent

<MudCard>
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudIcon Icon="@Icons.Material.Filled.Fingerprint" Color="Color.Primary" />
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">@Model.Localizer["Header_Title"]</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Model.Localizer["Header_Subtitle"]</MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        @if (Model.IsPrfSupported is null)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                <MudText>@Model.Localizer["Status_CheckingPrf"]</MudText>
            </MudStack>
        }
        else if (Model.IsPrfSupported == false)
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">
                @Model.Localizer["Alert_PrfNotSupported"]
            </MudAlert>
        }
        else
        {
            <MudTextField @bind-Value="@Model.DisplayName"
                          Label="@(Model.Localizer["Field_DisplayNameLabel"])"
                          Variant="Variant.Outlined"
                          HelperText="@(Model.Localizer["Field_DisplayNameHelper"])"
                          Class="mb-4"
                          Disabled="@Model.Register.Executing" />
        }
    </MudCardContent>

    <MudCardActions>
        <MudButtonAsyncRx Command="@Model.Register"
                          Variant="Variant.Filled"
                          Color="Color.Primary"
                          StartIcon="@Icons.Material.Filled.Key">
            @Model.Localizer["Btn_Register"]
        </MudButtonAsyncRx>
    </MudCardActions>
</MudCard>
