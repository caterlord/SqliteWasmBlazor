# Delta relay runtime artifacts — generated by `cryptosync-relay-init` and
# the LiveRelay integration tests. The committed `relay-config.example.php`
# is the operator template; the live `relay-config.php` is per-deployment.
DeltaRelay/relay-config.php
DeltaRelay/relay.db
DeltaRelay/relay.db-wal
DeltaRelay/relay.db-shm
