<Project>
  <PropertyGroup>
    <!-- Centralized version management -->
    <SqliteWasmBlazorVersion>0.9.1-pre</SqliteWasmBlazorVersion>

    <!-- Suppress WASM warnings globally for all projects in the solution -->

    <!-- WASM0001: varargs functions in native libraries (SQLite sqlite3_config, MSBuild GetModuleFileName) -->
    <!-- These are expected for native interop and don't affect runtime behavior -->

    <!-- CA1416: Validate platform compatibility -->
    <!-- Blazor WASM apps are always browser-only, platform checks are unnecessary -->

    <!-- NU1608: transitive Roslyn version mismatch from EF Core Design's
         MSBuild bits (Workspaces.MSBuild 5.0.0 wants Workspaces.Common = 5.0.0,
         we resolve 5.3.0 via GeneratorRunner). 5.3.0 is API-compatible with
         5.0.0 for our use, so the resolution is intentional. -->
    <NoWarn>$(NoWarn);WASM0001;WASM0060;WASM0062;CA1416;NU1608</NoWarn>
  </PropertyGroup>
</Project>
